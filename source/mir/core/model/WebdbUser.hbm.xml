<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-2.0.dtd" >
    
<hibernate-mapping>

<!-- 
    Created by Middlegen Hibernate plugin

    http://boss.bekk.no/boss/middlegen/
    http://hibernate.sourceforge.net/
-->

<class 
    name="mir.core.model.MirUser" 
    table="webdb_users"
>
    <id
        name="id"
        type="int"
        column="id"
    >
        <generator class="sequence" />
    </id>
    <property
        name="login"
        type="java.lang.String"
        column="login"
        not-null="true"
        length="16"
    />
    <property
        name="password"
        type="java.lang.String"
        column="password"
        not-null="true"
        length="16"
    />
    <property
        name="isAdmin"
        type="boolean"
        column="is_admin"
        not-null="true"
        length="1"
    />

    <!-- associations -->

</class>
</hibernate-mapping>
